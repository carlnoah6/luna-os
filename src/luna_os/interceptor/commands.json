{
  "$schema": "commands-schema",
  "version": 2,
  "commands": [
    {
      "id": "dashboard",
      "patterns": ["/dashboard", "仪表盘", "dashboard", "看板", "状态总览"],
      "handler": "dashboard",
      "description": "Show Luna task/plan dashboard"
    },
    {
      "id": "tasks",
      "patterns": ["/tasks", "任务列表", "task list", "待办", "todo", "看看任务", "有什么任务"],
      "handler": "tasks",
      "description": "List current tasks"
    },
    {
      "id": "model",
      "patterns": ["/model", "切换模型", "换模型", "当前模型"],
      "handler": "model",
      "description": "Show or switch LLM model"
    },
    {
      "id": "new",
      "patterns": ["/new", "新对话", "新会话", "重新开始", "清空上下文"],
      "handler": "new",
      "description": "Start a fresh conversation session"
    },
    {
      "id": "plan",
      "patterns": ["/plan", "计划状态", "plan status", "计划进度"],
      "handler": "plan",
      "description": "Show current plan execution status"
    },
    {
      "id": "usage",
      "patterns": ["/usage", "花费", "cost", "token用量", "token usage", "花了多少钱"],
      "handler": "usage",
      "description": "Show token usage and cost"
    },
    {
      "id": "help",
      "patterns": ["/help", "帮助", "你能做什么", "有什么功能"],
      "handler": "help",
      "description": "Show available commands"
    },
    {
      "id": "timeline",
      "patterns": ["/timeline", "时间线", "timeline", "活动记录", "最近做了什么"],
      "handler": "timeline",
      "description": "Show activity timeline"
    },
    {
      "id": "status",
      "patterns": ["/status", "系统状态"],
      "handler": "status",
      "description": "Show system status (model, context, session)"
    },
    {
      "id": "commands",
      "patterns": ["/commands", "命令列表", "所有命令"],
      "handler": "commands",
      "description": "List all available interceptor commands"
    },
    {
      "id": "stop",
      "patterns": ["/stop", "停止", "stop"],
      "handler": "stop",
      "description": "Stop current running task/plan"
    },
    {
      "id": "compact",
      "patterns": ["/compact", "压缩上下文", "compact"],
      "handler": "compact",
      "description": "Compact current session context"
    }
  ]
}
